# Install needed taps
tap "homebrew/bundle"
tap "homebrew/cask"
tap "homebrew/core"
tap "homebrew/services"
tap "buo/cask-upgrade"
# Mac App Store
# brew "mas"

# Basic useful commands
brew "bash"
brew "git"
brew "lynx"
brew "autoconf"
brew "wget"
brew "xz"
brew "awscli"
brew "libidn2"
brew "exiftool"
brew "fish"
brew "unixodbc"
brew "git-flow"
brew "jq"
brew "libusb-compat"

# MAMP setup
brew "httpd", restart_service: true
brew "mysql@5.7", restart_service: true
brew "php@7.3"

# Node and ruby 
brew "node"
brew "python@3.9"
brew "rbenv"
brew "swiftformat"
brew "terminal-notifier"
brew "uncrustify"

